{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xodnr927-byte/repro-evidence-kit/schemas/trust-policy.schema.json",
  "title": "Repro Evidence Signer Trust Policy",
  "description": "Shape validation for a local signer-trust policy. The parser additionally rejects duplicate IDs, unsupported resolver references, embedded key material, and contradictory timestamps. This schema does not prove signer identity or artifact correctness.",
  "type": "object",
  "additionalProperties": false,
  "required": ["policy_version", "policy_id", "keys"],
  "properties": {
    "policy_version": {"const": "1.0"},
    "policy_id": {"type": "string", "minLength": 1, "pattern": "^[^\\u0000-\\u001f\\u007f\\s]+$"},
    "keys": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/key"}
    }
  },
  "$defs": {
    "key": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key_id", "algorithm", "key_ref", "state", "not_before"],
      "properties": {
        "key_id": {"type": "string", "minLength": 1, "pattern": "^[^\\u0000-\\u001f\\u007f\\s]+$"},
        "algorithm": {"const": "hmac-sha256"},
        "key_ref": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(env:[A-Za-z_][A-Za-z0-9_]*|file:(?!//)[^\\u0000-\\u001f\\u007f\\r\\n]+)$"
        },
        "state": {"enum": ["active", "verify_only", "revoked"]},
        "not_before": {"type": "string", "format": "date-time"},
        "revoked_at": {"type": "string", "format": "date-time"},
        "comment": {"type": "string", "minLength": 1}
      }
    }
  }
}
